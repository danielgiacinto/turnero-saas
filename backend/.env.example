PORT=3000
NODE_ENV=development

# Conexión Supabase (ver schema.prisma → datasource db)
DIRECT_URL="postgresql://usuario:password@host:5432/postgres"
DATABASE_URL="postgresql://usuario:password@host:5432/postgres"

# Autenticación staff
JWT_SECRET="cambiar-por-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Google Identity (OAuth) — mismo Client ID en backend y frontend
GOOGLE_CLIENT_ID=""

# URL del frontend (links de invitación)
FRONTEND_URL="http://localhost:4200"

# Email — opcional en desarrollo (sin SMTP el código se imprime en la consola del backend)
# Ejemplos: Gmail (app password), Mailtrap, SendGrid, Resend SMTP, etc.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Turnero <no-reply@tudominio.com>"
