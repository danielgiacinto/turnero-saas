generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TipoRubro {
  estetica
  barberia
  salud_medicina
  psicologia
  nutricion
  medicina
}

enum RolUsuario {
  super_admin
  admin
  profesional
}

enum EstadoTurno {
  pendiente_verificacion
  pendiente
  completo
  cancelado
  inasistencia
}

enum OrigenReserva {
  portal_publico
  panel_staff
}

enum ConfirmacionAsistencia {
  no_requerida
  pendiente
  confirmada
  rechazada
  expirada
}

enum PropositoVerificacion {
  registro_cliente
  acceso_portal
  reenvio_identidad
}

enum CanalVerificacion {
  email
  whatsapp
  sms
}

enum PoliticaNoConfirmacion {
  cancelar
  mantener
}

enum EstadoSuscripcion {
  pendiente
  activa
  suspendida
  cancelada
}

enum ModalidadServicio {
  presencial
  online
}

enum CanalNotificacion {
  whatsapp
  email
}

enum EstadoNotificacion {
  pendiente
  enviado
  fallido
}

enum TipoMovimiento {
  ingreso
  egreso
}

enum MetodoPago {
  efectivo
  transferencia
}

enum EstadoInvitacion {
  pendiente
  aceptada
  expirada
}

model Comercio {
  id                                 String                 @id @default(uuid()) @db.Uuid
  nombre                             String
  url                                String                 @unique
  estado_suscripcion                 EstadoSuscripcion
  direccion                          String?
  barrio                             String
  rubro                              TipoRubro
  fecha_vencimiento                  DateTime
  created_at                         DateTime               @default(now())
  mp_preapproval_id                  String?
  logo_url                           String?
  requiere_confirmacion_asistencia   Boolean                @default(true)
  horas_anticipacion_confirmacion    Int                    @default(24)
  minutos_hold_reserva_sin_verificar Int                    @default(15)
  minutos_expiracion_codigo_otp      Int                    @default(10)
  politica_no_confirmacion           PoliticaNoConfirmacion @default(cancelar)

  usuarios       Usuario[]
  servicios      Servicio[]
  turnos         Turno[]
  fichas         Ficha[]
  movimientos    Movimiento[]
  notificaciones Notificacion[]
  invitaciones   Invitacion[]

  @@map("comercios")
}

model Usuario {
  id                    String     @id @default(uuid()) @db.Uuid
  comercio_id           String?    @db.Uuid
  nombre                String
  email                 String     @unique
  password              String?
  google_id             String?    @unique
  telefono              String?
  rol                   RolUsuario
  matricula_profesional String?
  biografia             String?
  porcentaje_comision   Decimal    @default(0) @db.Decimal(10, 2)
  activo                Boolean    @default(true)

  comercio       Comercio?    @relation(fields: [comercio_id], references: [id])
  horarios       Horario[]
  turnos         Turno[]
  turnos_creados Turno[]      @relation("TurnosCreadosPorStaff")
  fichas         Ficha[]
  movimientos    Movimiento[]
  invitaciones   Invitacion[]

  @@map("usuarios")
}

model Horario {
  id          String   @id @default(uuid()) @db.Uuid
  usuario_id  String   @db.Uuid
  dia_semana  Int
  hora_inicio DateTime @db.Time(0)
  hora_fin    DateTime @db.Time(0)

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  @@map("horarios")
}

model Servicio {
  id               String            @id @default(uuid()) @db.Uuid
  comercio_id      String            @db.Uuid
  nombre           String
  duracion_minutos Int
  precio           Decimal           @db.Decimal(10, 2)
  modalidad        ModalidadServicio

  comercio Comercio @relation(fields: [comercio_id], references: [id])
  turnos   Turno[]

  @@map("servicios")
}

model Cliente {
  id                        String    @id @default(uuid()) @db.Uuid
  nombre                    String
  apellido                  String
  email                     String    @unique
  telefono                  String
  email_verificado          Boolean   @default(false)
  telefono_verificado       Boolean   @default(false)
  email_verificado_fecha    DateTime?
  telefono_verificado_fecha DateTime?
  token_acceso_portal       String?   @unique

  turnos         Turno[]
  fichas         Ficha[]
  verificaciones Verificacion[]
  notificaciones Notificacion[]

  @@index([telefono])
  @@map("clientes")
}

model Turno {
  id                             String                 @id @default(uuid()) @db.Uuid
  comercio_id                    String                 @db.Uuid
  cliente_id                     String                 @db.Uuid
  profesional_id                 String                 @db.Uuid
  servicio_id                    String                 @db.Uuid
  link_reunion                   String?
  estado                         EstadoTurno
  origen_reserva                 OrigenReserva
  creado_por_usuario_id          String?                @db.Uuid
  fecha_hora                     DateTime
  reserva_expira_fecha           DateTime?
  confirmacion_asistencia        ConfirmacionAsistencia @default(no_requerida)
  confirmacion_asistencia_fecha  DateTime?
  limite_confirmacion_asistencia DateTime?

  comercio       Comercio       @relation(fields: [comercio_id], references: [id])
  cliente        Cliente        @relation(fields: [cliente_id], references: [id])
  profesional    Usuario        @relation(fields: [profesional_id], references: [id])
  servicio       Servicio       @relation(fields: [servicio_id], references: [id])
  creado_por     Usuario?       @relation("TurnosCreadosPorStaff", fields: [creado_por_usuario_id], references: [id])
  movimientos    Movimiento[]
  notificaciones Notificacion[]
  verificaciones Verificacion[]

  @@index([profesional_id, fecha_hora])
  @@index([comercio_id, estado])
  @@map("turnos")
}

model Ficha {
  id                String    @id @default(uuid()) @db.Uuid
  comercio_id       String    @db.Uuid
  cliente_id        String    @db.Uuid
  profesional_id    String    @db.Uuid
  fecha             DateTime
  datos_dinamicos   Json
  visible_cliente   Boolean   @default(false)
  titulo_cliente    String?
  contenido_cliente Json?
  publicado_fecha   DateTime?

  comercio    Comercio @relation(fields: [comercio_id], references: [id])
  cliente     Cliente  @relation(fields: [cliente_id], references: [id])
  profesional Usuario  @relation(fields: [profesional_id], references: [id])

  @@map("fichas")
}

model Movimiento {
  id                         String         @id @default(uuid()) @db.Uuid
  comercio_id                String         @db.Uuid
  turno_id                   String?        @db.Uuid
  profesional_id             String         @db.Uuid
  tipo                       TipoMovimiento
  monto                      Decimal        @db.Decimal(10, 2)
  metodo_pago                MetodoPago
  concepto                   String
  monto_comision_profesional Decimal        @db.Decimal(10, 2)
  fecha                      DateTime

  comercio    Comercio @relation(fields: [comercio_id], references: [id])
  turno       Turno?   @relation(fields: [turno_id], references: [id])
  profesional Usuario  @relation(fields: [profesional_id], references: [id])

  @@map("movimientos")
}

model Notificacion {
  id                 String             @id @default(uuid()) @db.Uuid
  comercio_id        String?            @db.Uuid
  turno_id           String?            @db.Uuid
  cliente_id         String?            @db.Uuid
  canal_notificacion CanalNotificacion
  destinatario       String
  plantilla_nombre   String
  datos_variables    Json
  fecha_programada   DateTime
  estado             EstadoNotificacion
  intentos           Int                @default(0)
  error_log          String?

  comercio Comercio? @relation(fields: [comercio_id], references: [id])
  turno    Turno?    @relation(fields: [turno_id], references: [id])
  cliente  Cliente?  @relation(fields: [cliente_id], references: [id])

  @@index([estado, fecha_programada])
  @@map("notificaciones")
}

model Verificacion {
  id           String                @id @default(uuid()) @db.Uuid
  cliente_id   String?               @db.Uuid
  turno_id     String?               @db.Uuid
  email        String?
  telefono     String?
  codigo_hash  String
  proposito    PropositoVerificacion
  canal        CanalVerificacion
  intentos     Int                   @default(0)
  max_intentos Int                   @default(5)
  expira_fecha DateTime
  usado_fecha  DateTime?
  created_at   DateTime              @default(now())

  cliente Cliente? @relation(fields: [cliente_id], references: [id])
  turno   Turno?   @relation(fields: [turno_id], references: [id])

  @@map("verificaciones")
}

model Invitacion {
  id          String           @id @default(uuid()) @db.Uuid
  comercio_id String           @db.Uuid
  email       String
  token       String           @unique
  estado      EstadoInvitacion @default(pendiente)
  usuario_id  String?          @db.Uuid
  expiration  DateTime
  created_at  DateTime         @default(now())

  comercio Comercio @relation(fields: [comercio_id], references: [id])
  usuario  Usuario? @relation(fields: [usuario_id], references: [id])

  @@map("invitaciones")
}
